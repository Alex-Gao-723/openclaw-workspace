#!/bin/bash
#
# Quick message sender wrapper for cron jobs
# Usage: message-send "recipient_id" "message content"
#

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_WRAPPER="$SCRIPT_DIR/message_wrapper.py"

# Default values
CHANNEL="kimi-claw"
RETRIES="3"

# Parse arguments
if [ $# -lt 2 ]; then
    echo "Usage: $0 <target_id> <message> [--channel <channel>] [--retries <n>]"
    echo "Example: $0 ou_1f6604399e414700d963393e24420570 'Hello Master!'"
    exit 1
fi

TARGET="$1"
shift
MESSAGE="$1"
shift

# Parse optional args
while [ $# -gt 0 ]; do
    case "$1" in
        --channel)
            CHANNEL="$2"
            shift 2
            ;;
        --retries)
            RETRIES="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

# Execute Python wrapper
exec python3 "$PYTHON_WRAPPER" "$TARGET" "$MESSAGE" --channel "$CHANNEL" --retries "$RETRIES"
